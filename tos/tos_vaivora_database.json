{
  "system": "vaivora_weapons",
  "game": "Tree of Savior",
  "version": "Episode 14+",
  "description": "Vaivora weapons are class-specific endgame weapons that enhance a designated skill with additional effects, procs, and damage multipliers. Each class has exactly one Vaivora weapon named after the skill it enhances.",
  "mechanics": {
    "acquisition": "Crafted from Vaivora Fragments (endgame raid drops) + class-specific materials. Cost: 500M-2B silver equivalent.",
    "weapon_swap_system": "Players can equip multiple weapon sets and auto-swap between them. Each Vaivora only activates when its weapon set is equipped. Swap triggers on skill use.",
    "scaling_tiers": [
      {
        "level": 1,
        "effect": "Base proc/enhancement"
      },
      {
        "level": 2,
        "effect": "+1 skill level to designated skill"
      },
      {
        "level": 3,
        "effect": "Major enhancement (often +100% Final Damage to one skill)"
      }
    ],
    "common_effects": [
      "Skill level +1/+2/+3 to designated skill",
      "New proc during skill use (extra hits, summons)",
      "Final Damage +30-100% on designated skill",
      "Cooldown reduction on designated skill",
      "Additional hits/targets on designated skill",
      "Unique mechanics (invincibility, teleport, element change)"
    ]
  },
  "impact_on_atk_calculations": {
    "direct_multipliers": "Final Damage bonuses (30-100%) are MULTIPLICATIVE with all other modifiers. Applied after Enhance/Arts/Commission chain.",
    "effective_sfr_boost": "Skill level +1-3 increases SFR array index, giving ~15-30% more base SFR per added level.",
    "proc_damage": "Random procs during dead time: 1800-3600% SFR × 1-4 hits, ~15% chance/sec. Fills rotation gaps.",
    "swap_multiplier": "Auto-swap between weapon sets grants +40% damage to burst skills during swap window.",
    "total_effective_multiplier": "Full Vaivora investment (lv3 + swap system) typically adds x1.8-x2.5 to a build's effective DPS.",
    "modeling_approach": "Template system models as: vaivora_investment = none | mid (lv1-2, no swap) | max (lv3, full swap). Applied as post-rotation multiplier to affected skills only."
  },
  "bonus_damage_system": {
    "formula": "Bonus% = (Offense_Stat - Defense_Stat) / (Defender_Level × 30) × 100",
    "pve_simplified": "Bonus% = Attack_vs_X / (Monster_Level × 30) × 100",
    "example": "At lv500 monster: 15,000 'Attack vs. Medium' = +100% damage (doubles it)",
    "properties": [
      "Flat bonus added AFTER main formula",
      "Bypasses defense entirely",
      "Vaivora weapons grant large 'Attack vs.' values",
      "Stacks additively with other sources of same property bonus",
      "Monster has no offsetting stat in PvE (offsetting = 0)"
    ],
    "types": [
      "Attack vs. Small",
      "Attack vs. Medium",
      "Attack vs. Large",
      "Attack vs. Ghost",
      "Attack vs. Plate",
      "Attack vs. Leather",
      "Attack vs. Cloth",
      "Attack vs. Plant",
      "Attack vs. Beast",
      "Attack vs. Insect",
      "Attack vs. Mutant",
      "Attack vs. Devil"
    ]
  },
