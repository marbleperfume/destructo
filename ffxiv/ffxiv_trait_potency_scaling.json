  "purpose": "Maps pre-Lv94 (base) potencies vs post-Lv94 (mastery trait) potencies for level-scaled modeling",
  "source_priority": [
    "1. Official job guide (na.finalfantasyxiv.com/jobguide/) = current patch potencies (Lv100, post-all-traits)",
    "2. consolegameswiki.com/wiki/{Skill_Name} Notes sections = pre-trait potencies",
    "3. Patch 7.0/7.1/7.2 history entries on wiki pages = delta confirmation"
  ],
  "global_traits": {
    "Increased Action Damage (Lv50)": "+10% base action damage (multiplicative)",
    "Increased Action Damage II (Lv60)": "+20% base action damage (replaces Lv50 trait)",
    "note": "These affect ALL damage actions. Pre-50: x1.0, 50-59: x1.1, 60+: x1.2. Baked into damage formula, not tooltips."
  },
